# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[pass]@db.[ref].supabase.co:5432/postgres

# Supabase Auth
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# Frontend env vars (must be set in Vercel too)
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_API_URL=http://localhost:4000

# Google Gemini (required for image generation)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=AIzaSy...

# Optional: multiple keys for load balancing (comma-separated, from different Google projects)
# GOOGLE_GEMINI_API_KEYS=key1,key2,key3

# Admin access (comma-separated emails)
ADMIN_EMAILS=you@example.com

# Optional: AI cost tracking
# AI_PRICING_JSON={"gemini":{"gemini-2.5-flash-image":{"inputPer1M":0.15,"outputPer1M":0.60},"gemini-3.1-flash-image-preview":{"inputPer1M":0.20,"outputPer1M":0.80},"gemini-3-pro-image-preview":{"inputPer1M":0.30,"outputPer1M":1.20}}}
