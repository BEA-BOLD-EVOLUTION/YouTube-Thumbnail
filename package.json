{
  "name": "youtube-thumbnail",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@9.8.1",
  "engines": {
    "node": ">=20.9.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "db:generate": "cd apps/api && npx prisma@5.22.0 generate",
    "db:push": "cd apps/api && npx prisma@5.22.0 db push",
    "db:migrate": "cd apps/api && npx prisma@5.22.0 migrate dev",
    "db:studio": "cd apps/api && npx prisma@5.22.0 studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "^8.5.12",
    "next": {
      "postcss": "^8.5.12"
    }
  }
}
